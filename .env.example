# .env.example
# 请复制此文件为 .env 并填入真实信息

# ================= Telegram API 配置 (可选) =================
API_ID=
API_HASH=

# ================= Bot 配置 (必填) =================
BOT_TOKEN=

# ================= 系统运行配置 =================
# Web 服务运行端口 (默认 8011，如果端口冲突可随时更改)
PORT=8011

# 盲猜模式连续失败熔断阈值 (默认 10)
# 当连续遇到 400 错误(消息不存在)达到此数值时，强制停止任务防封号
MAX_FAILS=10